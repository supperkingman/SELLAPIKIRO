# Sao chép file này thành .env rồi điền giá trị thật:
#   cp .env.example .env
#
# LƯU Ý: file .env chứa secret, đã được .gitignore. Không commit lên git.

# Mật khẩu đăng nhập trang quản trị https://api.mmodiary.com/admin
# Đặt mật khẩu mạnh (>= 16 ký tự, gồm chữ hoa, chữ thường, số, ký tự đặc biệt).
# Nếu để trống, bootstrap.sh sẽ tự sinh mật khẩu mạnh và in ra 1 lần để bạn lưu.
ADMIN_PASSWORD=doi_mat_khau_nay_thanh_mat_khau_manh

# --- Cấu hình đa site (chỉ cần đổi khi chạy NHIỀU site trên cùng 1 VPS) ---
# Mỗi site phải có SITE_NAME khác nhau (tránh trùng tên container) và bộ cổng riêng.
# Site đầu tiên có thể để mặc định.
SITE_NAME=kiro
KIRO_PORT=8080
KEYCHECK_PORT=8081
KEYADMIN_PORT=8082
STOREFRONT_PORT=8083

# --- API keyadmin cho bot Telegram (tạo & quản lý key qua bearer token) ---
# Bot phải gửi header "Authorization: Bearer <token>". Sinh token mạnh, ví dụ:
#   openssl rand -hex 32
# Để trống thì service keyadmin sẽ TỪ CHỐI khởi động (tránh API không bảo vệ).
KEYADMIN_TOKEN=doi_token_nay_thanh_token_ngau_nhien_manh

# --- Cloudflare Turnstile (captcha chống dò key ở trang /check-key) ---
# Lấy tại: dashboard.cloudflare.com -> Turnstile -> Add site.
#   - Secret Key -> điền vào đây (server keycheck dùng để verify).
#   - Site Key   -> dán vào web-custom/check-key.html (window.TURNSTILE_SITEKEY).
# Để TRỐNG cả hai -> captcha bị TẮT (trang vẫn chạy bình thường).
TURNSTILE_SECRET=

# --- Storefront (web ban API cho khach + admin, Shopify-style) ---
# Tieu de site hien tren giao dien.
STOREFRONT_TITLE=Kiro API Store
# Ti gia quy doi USD -> VND (hien gia VND o trang mua/checkout).
USD_TO_VND=25000
# Cookie Secure: dat "false" khi test HTTP local (localhost), "true" khi chay HTTPS that.
STOREFRONT_SECURE_COOKIE=true
# Thong tin thanh toan (khach thay o trang don hang; co the sua lai trong Admin > Cai dat).
BANK_NAME=Vietcombank
BANK_ACCOUNT=0123456789
BANK_HOLDER=NGUYEN VAN A
# Tien to noi dung chuyen khoan; he thong tu chen kem ma don, vd: "KIRO KIRO-AB12CD".
BANK_CONTENT_PREFIX=KIRO
# Link anh QR chuyen khoan (de trong neu chua co).
BANK_QR_URL=

# --- URL cong khai (bat buoc cho OAuth callback + PayPal return) ---
# Vi du: https://shop.mmodiary.com  (KHONG co dau / o cuoi). Local: http://localhost:8083
PUBLIC_BASE_URL=http://localhost:8083

# --- SePay (tu dong xac nhan chuyen khoan VND qua webhook) ---
# Tao tai my.sepay.vn -> Cong ty -> Webhooks. Dat URL: <PUBLIC_BASE_URL>/webhook/sepay
# va header xac thuc "Authorization: Apikey <token>". Dien token do vao day.
# De TRONG -> cong SePay bi AN tren trang thanh toan.
SEPAY_API_KEY=

# --- BEP20 USDT (Binance Smart Chain) ---
# Dia chi vi nhan USDT (BEP20). Vi du: 0x...  De TRONG -> an cong crypto.
USDT_WALLET_ADDRESS=
# API key BscScan (bscscan.com -> API-KEYs). Dung de verify giao dich on-chain.
BSCSCAN_API_KEY=

# --- PayPal (USD) ---
# Tao tai developer.paypal.com -> Apps & Credentials. De TRONG -> an cong PayPal.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# "true" = moi truong that (live), "false" = sandbox de test.
PAYPAL_LIVE=false

# --- Google OAuth (dang nhap nhanh) ---
# Tao tai console.cloud.google.com -> APIs & Services -> Credentials -> OAuth client ID (Web).
# Authorized redirect URI: <PUBLIC_BASE_URL>/auth/google/callback
# De TRONG -> nut "Dang nhap voi Google" bi an.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
